    /**
     * Calculate priority score based on type weight and recency
     * Formula: (typeWeight * 100) + (recencyScore)
     * Recency: Newer = Higher score
     */
    calculatePriorityScore(notification) {
        logger.logFunctionEntry('calculatePriorityScore', {
            notificationId: notification.ID,
            type: notification.Type
        });
        
        const typeWeight = this.WEIGHTS[notification.Type] || 0;
        
        // Parse timestamp
        const timestamp = new Date(notification.Timestamp);
        const now = new Date();
        const ageMs = now.getTime() - timestamp.getTime();
        const ageHours = ageMs / (1000 * 60 * 60);
        
        // Recency score: Newer = Higher
        // Decay over time: Max 100 at 0 hours, 0 at 7 days
        const maxAgeHours = 7 * 24;
        const recencyScore = Math.max(0, 100 * (1 - ageHours / maxAgeHours));
        
        // Combined score: Type weight has more influence
        const priorityScore = (typeWeight * 100) + recencyScore;
        
        logger.debug('Priority score calculated', {
            context: 'PRIORITY_CALC',
            notificationId: notification.ID,
            type: notification.Type,
            typeWeight,
            ageHours: parseFloat(ageHours.toFixed(2)),
            recencyScore: parseFloat(recencyScore.toFixed(2)),
            priorityScore: parseFloat(priorityScore.toFixed(2))
        });
        
        logger.logFunctionExit('calculatePriorityScore', {
            priorityScore: parseFloat(priorityScore.toFixed(2))
        });
        
        return priorityScore;
    }
    
    /**
     * Enhance notifications with priority score
     */
    enrichNotificationsWithPriority(notifications) {
        logger.logFunctionEntry('enrichNotificationsWithPriority', {
            notificationCount: notifications.length
        });
        
        const enriched = notifications.map(notification => ({
            ...notification,
            priorityScore: this.calculatePriorityScore(notification),
            timestamp: new Date(notification.Timestamp)
        }));
        
        logger.logFunctionExit('enrichNotificationsWithPriority', {
            enrichedCount: enriched.length
        });
        
        return enriched;
    }
    
    /**
     * Get top N notifications sorted by priority
     */
    getTopNotifications(notifications, limit = 10) {
        logger.logFunctionEntry('getTopNotifications', {
            totalNotifications: notifications.length,
            limit
        });
        
        const sorted = [...notifications].sort((a, b) => {
            // Primary: Sort by priority score descending
            if (b.priorityScore !== a.priorityScore) {
                return b.priorityScore - a.priorityScore;
            }
            // Secondary: Sort by timestamp descending (newest first)
            return b.timestamp.getTime() - a.timestamp.getTime();
        });
        
        const topNotifications = sorted.slice(0, limit);
        
        logger.info('Top notifications extracted', {
            context: 'PRIORITY_RANKING',
            totalNotifications: notifications.length,
            limit,
            returnedCount: topNotifications.length
        });
        
        // Log distribution of top 10 by type
        const distribution = {};
        topNotifications.forEach(n => {
            distribution[n.Type] = (distribution[n.Type] || 0) + 1;
        });
        
        logger.info('Priority inbox distribution', {
            context: 'DISTRIBUTION',
            distribution
        });
        
        logger.logFunctionExit('getTopNotifications', {
            returnedCount: topNotifications.length
        });
        
        return topNotifications;
    }
    
    /**
     * Format notification for display
     */
    formatNotificationForDisplay(notification, index) {
        const timestamp = notification.timestamp instanceof Date 
            ? notification.timestamp 
            : new Date(notification.Timestamp);
        
        const ageMs = new Date().getTime() - timestamp.getTime();
        const ageHours = Math.floor(ageMs / (1000 * 60 * 60));
        const ageMinutes = Math.floor((ageMs % (1000 * 60 * 60)) / (1000 * 60));
        const ageDays = Math.floor(ageMs / (1000 * 60 * 60 * 24));
        
        let timeAgo;
        if (ageDays > 0) {
            timeAgo = `${ageDays}d ${ageHours % 24}h ago`;
        } else if (ageHours > 0) {
            timeAgo = `${ageHours}h ${ageMinutes}m ago`;
        } else {
            timeAgo = `${ageMinutes}m ago`;
        }
        
        const typeEmoji = {
            'Placement': '💼',
            'Result': '📊',
            'Event': '🎉'
        };
        
        return {
            rank: index + 1,
            id: notification.ID,
            type: notification.Type,
            typeEmoji: typeEmoji[notification.Type] || '📬',
            message: notification.Message,
            timestamp: timestamp.toISOString().split('T')[0],
            timeAgo,
            priorityScore: parseFloat(notification.priorityScore.toFixed(2))
        };
    }
    
